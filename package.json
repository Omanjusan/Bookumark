{
  "name": "bookumark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "under construction - customizable bookmark firefox add-on",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:dev": "node scripts/build.mjs --development",
    "preexperiment": "npm run build:dev",
    "experiment": "web-ext run --source-dir dist --firefox=flatpak:org.mozilla.firefox --firefox-profile=develop --keep-profile-changes",
    "prelint:ext": "npm run build",
    "lint:ext": "web-ext lint --source-dir dist",
    "test": "npm run build && node --test test/*.test.mjs",
    "benchmark:panel": "npm run build && node scripts/benchmark-panel.mjs"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "typescript": "^7.0.2",
    "web-ext": "^8.0.0"
  }
}
